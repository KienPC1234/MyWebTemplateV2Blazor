@using Microsoft.AspNetCore.Components.Web
@using MyWebTemplateV2.Client
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FPT Nexus — Hệ thống quản lý doanh nghiệp thông minh chuẩn tập đoàn FPT." />
    <base href="/" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

    <!-- NeoUI: đúng thứ tự theo docs -->
    <link href="@Assets["_content/NeoUI.Blazor/components.css"]" rel="stylesheet" />
    <!-- Base: neutral (sạch sẽ, chuyên nghiệp) -->
    <link href="@Assets["_content/NeoUI.Blazor/css/themes/base/neutral.css"]" rel="stylesheet" />
    <!-- Primary: orange (màu FPT) -->
    <link href="@Assets["_content/NeoUI.Blazor/css/themes/primary/orange.css"]" rel="stylesheet" />
    <!-- Style: Maia (spacious, consumer-friendly) -->
    <link href="@Assets["_content/NeoUI.Blazor/css/themes/styles/maia.css"]" rel="stylesheet" />
    <!-- Radius: Medium (chuyên nghiệp, không bo quá nhiều) -->
    <link href="@Assets["_content/NeoUI.Blazor/css/themes/radius/medium.css"]" rel="stylesheet" />
    <!-- Font: PlusJakarta (Maia preset font) -->
    <link href="@Assets["_content/NeoUI.Blazor/css/themes/fonts/plusjakarta.css"]" rel="stylesheet" />
    <!-- Theme init script - phải trước Blazor để tránh FOUC -->
    <script src="@Assets["_content/NeoUI.Blazor/js/theme.js"]"></script>
    <!-- App CSS (Tailwind compiled) - sau NeoUI -->
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["MyWebTemplateV2.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveWebAssembly" />
</head>

<body>
    <Routes @rendermode="InteractiveWebAssembly" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
