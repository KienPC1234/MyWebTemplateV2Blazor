@inherits LayoutComponentBase
@using NeoUI.Blazor
@using NeoUI.Blazor.Primitives
@using NeoUI.Blazor.Primitives.Services
@using NeoUI.Icons.Lucide

<AppProvider>
    <div class="min-h-screen flex flex-col bg-background">
        
        <!-- Floating Navbar -->
        <div class="nav-floating">
            <div class="nav-floating-inner">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="nav-brand-icon">
                        <LucideIcon Name="flame" class="h-4 w-4" />
                    </div>
                    <span class="font-extrabold text-lg tracking-tight hidden sm:block" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                        Nexus
                    </span>
                </div>
                
                <!-- Nav Links -->
                <div class="nav-links">
                    <NavLink href="/" Match="NavLinkMatch.All">Trang chủ</NavLink>
                    <NavLink href="/features">Tính năng</NavLink>
                    <NavLink href="/pricing">Bảng giá</NavLink>
                    <NavLink href="/docs">Tài liệu</NavLink>
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-2">
                    <DarkModeToggle />
                    <Button Variant="ButtonVariant.Default" Size="ButtonSize.Default" class="rounded-full px-5 hidden sm:flex">
                        Bắt đầu
                    </Button>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <main class="flex-1">
            @Body
        </main>
        
        <!-- Footer -->
        <footer class="site-footer">
            <div class="site-footer-inner">
                <div class="flex items-center gap-3">
                    <div class="nav-brand-icon" style="width:1.75rem;height:1.75rem;border-radius:0.5rem;">
                        <LucideIcon Name="flame" class="h-3.5 w-3.5" />
                    </div>
                    <span class="font-bold tracking-tight text-sm" style="font-family:'Plus Jakarta Sans',sans-serif;">Nexus Enterprise</span>
                </div>
                <div class="flex flex-wrap justify-center gap-6 text-sm">
                    <a href="#" class="hover:text-primary transition-colors">Điều khoản</a>
                    <a href="#" class="hover:text-primary transition-colors">Bảo mật</a>
                    <a href="#" class="hover:text-primary transition-colors">Liên hệ</a>
                </div>
                <span>&copy; 2026 Nexus Inc. Bảo lưu mọi quyền.</span>
            </div>
        </footer>
    </div>

    <!-- NeoUI Portal Hosts -->
    <ToastViewport />
    <DialogHost />
    <CategoryPortalHost Category="PortalCategory.Overlay" />
    <CategoryPortalHost Category="PortalCategory.Container" />
    <OverlayPortalHost />
</AppProvider>
