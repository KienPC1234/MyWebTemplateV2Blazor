@inherits LayoutComponentBase
@using NeoUI.Blazor
@using NeoUI.Blazor.Primitives
@using NeoUI.Blazor.Primitives.Services
@using NeoUI.Icons.Lucide

<AppProvider>
    <div class="min-h-screen flex flex-col bg-white">
        
        <!-- FPT Official Header -->
        <header class="fpt-header">
            <div class="fpt-nav-container">
                <!-- Brand -->
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-1 group">
                        <!-- Simulated FPT Logo Blocks -->
                        <div class="w-4 h-8 bg-fpt-orange -skew-x-[13deg] transition-transform group-hover:scale-110"></div>
                        <div class="w-4 h-8 bg-fpt-green -skew-x-[13deg] transition-transform group-hover:scale-110"></div>
                        <div class="w-4 h-8 bg-fpt-blue -skew-x-[13deg] transition-transform group-hover:scale-110"></div>
                    </div>
                    <div class="flex flex-col leading-none">
                        <span class="text-2xl font-black tracking-tighter text-fpt-blue italic">FPT</span>
                        <span class="text-[10px] font-bold tracking-widest text-fpt-orange uppercase">Nexus Enterprise</span>
                    </div>
                </div>
                
                <!-- Links -->
                <nav class="hidden md:flex items-center gap-10">
                    <NavLink href="/" Match="NavLinkMatch.All" class="nav-link" ActiveClass="nav-active">Trang chủ</NavLink>
                    <NavLink href="/features" class="nav-link" ActiveClass="nav-active">Tính năng</NavLink>
                    <NavLink href="/solutions" class="nav-link" ActiveClass="nav-active">Giải pháp</NavLink>
                    <NavLink href="/docs" class="nav-link" ActiveClass="nav-active">Tài liệu</NavLink>
                </nav>

                <!-- Actions -->
                <div class="flex items-center gap-4">
                    <button class="btn-fpt">Liên hệ</button>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="flex-1">
            @Body
        </main>
        
        <!-- FPT Official Footer -->
        <footer class="fpt-footer bg-white border-t border-border">
            <div class="max-w-7xl mx-auto px-6">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
                    <div class="col-span-2">
                        <div class="flex items-center gap-2 mb-6">
                            <div class="w-3 h-6 bg-fpt-orange -skew-x-[13deg]"></div>
                            <div class="w-3 h-6 bg-fpt-green -skew-x-[13deg]"></div>
                            <div class="w-3 h-6 bg-fpt-blue -skew-x-[13deg]"></div>
                            <span class="text-xl font-black italic text-fpt-blue">FPT Nexus</span>
                        </div>
                        <p class="text-sm text-zinc-500 max-w-sm leading-relaxed">
                            Thành viên của Tập đoàn FPT. Tiên phong chuyển đổi số và cung cấp giải pháp công nghệ hiện đại cho doanh nghiệp toàn cầu.
                        </p>
                    </div>
                    <div>
                        <h4 class="text-xs font-bold uppercase tracking-widest text-fpt-blue mb-6">Sản phẩm</h4>
                        <ul class="space-y-4 text-sm text-zinc-600">
                            <li><a href="#" class="hover:text-fpt-orange">Phân tích dữ liệu</a></li>
                            <li><a href="#" class="hover:text-fpt-orange">Hệ thống ERP</a></li>
                            <li><a href="#" class="hover:text-fpt-orange">Cloud Computing</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-xs font-bold uppercase tracking-widest text-fpt-blue mb-6">Tài liệu</h4>
                        <ul class="space-y-4 text-sm text-zinc-600">
                            <li><a href="#" class="hover:text-fpt-orange">Brand Manual</a></li>
                            <li><a href="#" class="hover:text-fpt-orange">API Reference</a></li>
                            <li><a href="#" class="hover:text-fpt-orange">Chính sách bảo mật</a></li>
                        </ul>
                    </div>
                </div>
                
                <div class="footer-copyright">
                    <div class="flex items-center gap-8">
                        <span>Mã hiệu tài liệu: 01-QD/TH/HDCV/FPT</span>
                        <span>Version 3.1</span>
                        <span>Ngày hiệu lực: 01/03/2020</span>
                    </div>
                    <div>
                        &copy; 2026 FPT Corporation. Bảo lưu mọi quyền.
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <!-- NeoUI Portal Hosts -->
    <ToastViewport />
    <DialogHost />
    <CategoryPortalHost Category="PortalCategory.Overlay" />
    <CategoryPortalHost Category="PortalCategory.Container" />
    <OverlayPortalHost />
</AppProvider>
