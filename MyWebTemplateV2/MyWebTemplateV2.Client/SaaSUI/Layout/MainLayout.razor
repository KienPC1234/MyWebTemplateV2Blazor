@inherits LayoutComponentBase
@using MyWebTemplateV2.Client.SaaSUI.Components
@inject NavigationManager Nav

<div class="min-h-screen flex flex-col bg-white font-sans">
    
    <NavMenu />

    <!-- Main Content Canvas -->
    <main class="flex-1">
        @Body
    </main>

    <!-- AI Chat Ecosystem -->
    <AiChatWidget />
    
    <!-- FPT Signature Footer -->
    <footer class="bg-zinc-50 border-t border-zinc-200/50 pt-32 pb-16">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
                <div class="lg:col-span-5">
                    <div class="flex items-center gap-3 mb-10">
                        <div class="flex gap-1">
                            <div class="w-2 h-5 bg-fpt-orange -skew-x-[13deg]"></div>
                            <div class="w-2 h-5 bg-fpt-green -skew-x-[13deg]"></div>
                            <div class="w-2 h-5 bg-fpt-blue -skew-x-[13deg]"></div>
                        </div>
                        <span class="text-xl font-black italic text-fpt-blue uppercase ">Nhịp đập FPT</span>
                    </div>
                    <p class="text-lg text-zinc-500 leading-relaxed font-medium mb-12">
                        Kiến tạo không gian sáng tạo số, nơi tri thức và đam mê của học sinh FPT được kết nối, tôn vinh và lan tỏa.
                    </p>
                    
                    <div class="flex gap-4">
                        <button class="w-12 h-12 rounded-2xl bg-white border border-zinc-200 flex items-center justify-center text-zinc-400 hover:text-fpt-orange hover:border-fpt-orange/30 hover:shadow-lg hover:shadow-fpt-orange/10 transition-all duration-300">
                            <i class="bi bi-facebook fs-5"></i>
                        </button>
                        <button class="w-12 h-12 rounded-2xl bg-white border border-zinc-200 flex items-center justify-center text-zinc-400 hover:text-fpt-orange hover:border-fpt-orange/30 hover:shadow-lg hover:shadow-fpt-orange/10 transition-all duration-300">
                            <i class="bi bi-instagram fs-5"></i>
                        </button>
                        <button class="w-12 h-12 rounded-2xl bg-white border border-zinc-200 flex items-center justify-center text-zinc-400 hover:text-fpt-orange hover:border-fpt-orange/30 hover:shadow-lg hover:shadow-fpt-orange/10 transition-all duration-300">
                            <i class="bi bi-youtube fs-5"></i>
                        </button>
                        <button class="w-12 h-12 rounded-2xl bg-white border border-zinc-200 flex items-center justify-center text-zinc-400 hover:text-fpt-orange hover:border-fpt-orange/30 hover:shadow-lg hover:shadow-fpt-orange/10 transition-all duration-300">
                            <i class="bi bi-twitter-x fs-5"></i>
                        </button>
                    </div>
                </div>
                
                <div class="lg:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-16">
                    <div>
                        <h4 class="text-[10px] font-black uppercase text-fpt-blue mb-8">Hệ sinh thái</h4>
                        <ul class="space-y-4 text-sm font-bold text-zinc-400">
                            <li><a href="/" class="hover:text-fpt-orange transition-colors">Trang chủ</a></li>
                            <li><a href="/ngoai-khoa" class="hover:text-fpt-orange transition-colors">Hoạt động</a></li>
                            <li><a href="/lien-he" class="hover:text-fpt-orange transition-colors">Liên hệ</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-[10px] font-black uppercase text-fpt-blue mb-8">Nguồn lực</h4>
                        <ul class="space-y-4 text-sm font-bold text-zinc-400">
                            <li><a href="/mon-hoc/van" class="hover:text-fpt-orange transition-colors">Ấn phẩm Nhái Bén</a></li>
                            <li><a href="/mon-hoc/ktpl" class="hover:text-fpt-orange transition-colors">Tài liệu KTPL</a></li>
                            <li><a href="#" class="hover:text-fpt-orange transition-colors">Thư viện ảnh</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-[10px] font-black uppercase text-fpt-blue mb-8">Pháp lý</h4>
                        <ul class="space-y-4 text-sm font-bold text-zinc-400">
                            <li><a href="#" class="hover:text-fpt-orange transition-colors">Quy định gửi bài</a></li>
                            <li><a href="#" class="hover:text-fpt-orange transition-colors">Bảo mật thông tin</a></li>
                            <li><a href="#" class="hover:text-fpt-orange transition-colors">Bản quyền nội dung</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="mt-32 pt-12 border-t border-zinc-200/50 flex flex-col md:flex-row justify-between items-center gap-8">
                <div class="flex items-center gap-6 text-[9px] font-black uppercase text-zinc-400">
                    <span class="text-fpt-blue">© 2026 FPT Education</span>
                    <div class="w-1 h-1 bg-zinc-300 rounded-full"></div>
                    <span>Designed for Excellence</span>
                </div>
                <div class="flex items-center gap-6 text-[9px] font-black uppercase text-zinc-400">
                    <span>Version 4.0.0</span>
                    <div class="w-1 h-1 bg-zinc-300 rounded-full"></div>
                    <span>Status: Operational</span>
                </div>
            </div>
        </div>
    </footer>
</div>
