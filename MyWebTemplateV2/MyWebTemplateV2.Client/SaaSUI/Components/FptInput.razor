<div class="space-y-3 @Class" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="text-[10px] font-black uppercase text-zinc-500 mb-3 block ml-4">@Label</label>
    }
    <div class="relative group">
        @if (Icon != null || !string.IsNullOrEmpty(BootstrapIcon))
        {
            <div class="absolute left-6 top-1/2 -translate-y-1/2 text-zinc-400 group-focus-within:text-fpt-orange transition-colors">
                @if (Icon != null) { @Icon }
                else { <i class="bi bi-@BootstrapIcon"></i> }
            </div>
        }
        @if (Type == "textarea")
        {
            <textarea value="@Value" 
                      @oninput="OnInput" 
                      class="@GetInputClass()" 
                      placeholder="@Placeholder"
                      rows="@Rows"></textarea>
        }
        else
        {
            <input value="@Value" 
                   type="@Type" 
                   @oninput="OnInput" 
                   @onkeyup="OnKeyUp"
                   class="@GetInputClass()" 
                   placeholder="@Placeholder" />
        }
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string BootstrapIcon { get; set; } = "";
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyUp { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";
        await ValueChanged.InvokeAsync(Value);
    }

    private string GetInputClass()
    {
        var baseClass = "bg-zinc-50 border-2 border-transparent px-8 py-5 rounded-[2rem] text-sm font-bold text-zinc-800 outline-none transition-all duration-300 focus:border-fpt-orange focus:bg-white focus:shadow-xl focus:shadow-fpt-orange/5 w-full ";
        if (Icon != null || !string.IsNullOrEmpty(BootstrapIcon))
        {
            baseClass += "pl-16 ";
        }
        return baseClass;
    }
}
