@using System.Text
@using Markdig
@inject HttpClient Http
@inject IJSRuntime JS

<div class="fixed bottom-8 right-8 z-[100]">
    @if (!_isOpen)
    {
        <div class="relative group" data-aos="zoom-in">
            <div class="absolute inset-0 bg-gradient-to-r from-fpt-orange to-fpt-blue rounded-full blur-xl opacity-30 group-hover:opacity-60 transition-opacity animate-pulse"></div>
            <button @onclick="ToggleChat" class="ai-chat-toggle-btn w-20 h-20 bg-gradient-to-tr from-fpt-blue to-fpt-green text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all relative z-10 border-4 border-white/20 backdrop-blur-sm">
                <i class="bi bi-chat-dots-fill text-4xl"></i>
                <div class="absolute -top-3 -right-3 bg-fpt-orange text-[9px] font-black px-3 py-1 rounded-full border-2 border-white shadow-lg animate-bounce">AI LIVE</div>
            </button>
        </div>
    }
    else
    {
        <div class="w-[450px] h-[700px] bg-white/95 backdrop-blur-3xl border border-white/40 shadow-[0_30px_100px_-20px_rgba(0,0,0,0.5)] flex flex-col rounded-[2.5rem] overflow-hidden" data-aos="zoom-in-up">
            <!-- Header -->
            <div class="bg-gradient-to-r from-fpt-blue via-fpt-blue to-fpt-green p-6 flex justify-between items-center text-white relative overflow-hidden">
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
                
                <div class="flex items-center gap-4 relative z-10">
                    <div class="w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center border border-white/30 backdrop-blur-md shadow-inner">
                         <i class="bi bi-robot text-fpt-orange animate-pulse text-2xl"></i>
                    </div>
                    <div>
                        <div class="text-[10px] font-black uppercase text-white/70 tracking-widest">FPT Assistant</div>
                        <div class="text-xl font-black uppercase italic">Nhịp đập AI</div>
                    </div>
                </div>
                <div class="flex items-center gap-2 relative z-10">
                    <button @onclick="ClearChat" class="w-10 h-10 rounded-full hover:bg-white/20 flex items-center justify-center transition-all group" title="Xóa hội thoại">
                        <i class="bi bi-trash3 text-lg"></i>
                    </button>
                    <button @onclick="ToggleChat" class="w-10 h-10 rounded-full hover:bg-white/20 flex items-center justify-center transition-all group">
                        <i class="bi bi-x-lg group-hover:rotate-90 transition-transform"></i>
                    </button>
                </div>
            </div>

            <!-- Messages -->
            <div id="chat-messages-container" class="flex-1 overflow-y-auto p-8 space-y-8 bg-zinc-50/50 min-h-0 scroll-smooth">
                @foreach (var msg in _messages)
                {
                    <div class="flex @(msg.IsUser ? "justify-end" : "justify-start")">
                         <div class="flex flex-col gap-2 max-w-[85%] @(msg.IsUser ? "items-end" : "items-start")" data-aos="@(msg.IsUser ? "fade-left" : "fade-right")">
                            <div class="p-5 text-sm leading-relaxed @(msg.IsUser ? "bg-gradient-to-tr from-fpt-orange to-fpt-green text-white rounded-[2rem] rounded-tr-none shadow-xl shadow-fpt-orange/20" : "bg-white border border-zinc-100 text-zinc-800 rounded-[2rem] rounded-tl-none shadow-md") markdown-content relative group">
                                @((MarkupString)RenderMarkdown(msg.Text))
                            </div>
                            <div class="flex items-center gap-2 px-3">
                                @if (!msg.IsUser) { <div class="w-2 h-2 rounded-full bg-fpt-green animate-pulse"></div> }
                                <span class="text-[9px] font-black uppercase text-zinc-400 tracking-widest">@(msg.IsUser ? "You" : "Gemma AI")</span>
                                @if (msg.IsUser) { <div class="w-2 h-2 rounded-full bg-fpt-orange"></div> }
                            </div>
                         </div>
                    </div>
                }
                
                @if (_isThinking)
                {
                    <div class="flex justify-start">
                        <div class="flex flex-col gap-2 items-start" data-aos="fade-right">
                            <div class="bg-white border border-zinc-100 p-5 rounded-[2rem] rounded-tl-none shadow-md flex items-center gap-4">
                                <div class="flex gap-2">
                                    <div class="w-2.5 h-2.5 rounded-full bg-fpt-orange animate-bounce"></div>
                                    <div class="w-2.5 h-2.5 rounded-full bg-fpt-green animate-bounce" style="animation-delay: 0.2s"></div>
                                    <div class="w-2.5 h-2.5 rounded-full bg-fpt-blue animate-bounce" style="animation-delay: 0.4s"></div>
                                </div>
                                <span class="text-xs font-bold text-zinc-400 italic">AI đang xử lý...</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="p-6 bg-white border-t border-zinc-100 relative">
                <div class="flex items-end gap-3 bg-zinc-50 rounded-[2rem] p-2 border-2 border-transparent transition-all focus-within:bg-white focus-within:ring-4 focus-within:ring-fpt-orange/10 focus-within:border-fpt-orange/30 shadow-inner">
                    <textarea @bind="_userInput" @bind:event="oninput" @onkeyup="HandleKeyUp" 
                              class="flex-1 bg-transparent border-none text-sm outline-none px-4 py-3 resize-none max-h-32 overflow-y-auto font-medium" 
                              placeholder="Hỏi AI về hoạt động ngoại khóa..."
                              rows="1"></textarea>
                    <button @onclick="SendMessage" disabled="@(_isTyping || string.IsNullOrWhiteSpace(_userInput))" 
                            class="w-12 h-12 bg-fpt-blue text-white rounded-2xl shadow-xl shadow-fpt-blue/20 flex items-center justify-center hover:bg-fpt-orange hover:shadow-fpt-orange/30 hover:scale-105 active:scale-95 transition-all disabled:opacity-30 disabled:scale-100 flex-shrink-0 group">
                        @if (_isTyping) { <div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div> }
                        else { <i class="bi bi-send-fill text-xl group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"></i> }
                    </button>
                </div>
                <div class="mt-4 flex justify-center">
                    <p class="text-[9px] font-black uppercase text-zinc-300 tracking-widest">Powered by <span class="text-fpt-orange">FPT Education AI</span></p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isOpen = false;
    private string _userInput = "";
    private bool _isThinking = false;
    private bool _isTyping = false;
    private List<ChatMessage> _messages = new()
    {
        new ChatMessage { Text = "Xin chào! Tôi là trợ lý ảo FPT. Bạn cần tôi hỗ trợ gì về hoạt động ngoại khóa hôm nay?", IsUser = false }
    };

    private async Task ToggleChat()
    {
        _isOpen = !_isOpen;
        if (_isOpen)
        {
            await Task.Delay(100);
            await ScrollToBottom();
        }
    }

    private void ClearChat()
    {
        _messages = new List<ChatMessage>
        {
            new ChatMessage { Text = "Xin chào! Hội thoại đã được làm mới. Tôi có thể giúp gì cho bạn?", IsUser = false }
        };
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !string.IsNullOrWhiteSpace(_userInput))
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_userInput) || _isTyping) return;

        var userText = _userInput;
        _userInput = "";
        _messages.Add(new ChatMessage { Text = userText, IsUser = true });
        _isThinking = true;
        _isTyping = true;
        
        await ScrollToBottom();

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Post, "/api/chat");
            request.Content = JsonContent.Create(new { Prompt = userText });
            
            // Real HTTP streaming
            using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);
            
            if (response.IsSuccessStatusCode)
            {
                var aiMsg = new ChatMessage { Text = "", IsUser = false };
                _messages.Add(aiMsg);
                _isThinking = false;

                using var stream = await response.Content.ReadAsStreamAsync();
                using var reader = new StreamReader(stream);
                
                var buffer = new char[1]; // Read character by character for true streaming feel
                while (await reader.ReadAsync(buffer, 0, 1) > 0)
                {
                    aiMsg.Text += buffer[0];
                    StateHasChanged();
                    await Task.Delay(5); // Ultra-fast feel
                    await ScrollToBottom();
                }
            }
            else
            {
                _messages.Add(new ChatMessage { Text = "Xin lỗi, tôi gặp sự cố kết nối. Vui lòng thử lại sau.", IsUser = false });
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage { Text = $"Lỗi: {ex.Message}", IsUser = false });
        }
        finally
        {
            _isThinking = false;
            _isTyping = false;
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('chat-messages-container')?.scrollTo(0, 1000000)");
    }

    private string RenderMarkdown(string text)
    {
        var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
        return Markdown.ToHtml(text, pipeline);
    }

    public class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
    }
}

<style>
    .markdown-content p { @@apply mb-2 last:mb-0; }
    .markdown-content strong { @@apply font-black text-inherit; }
    .markdown-content ul, .markdown-content ol { @@apply pl-4 mb-2 space-y-1; }
    .markdown-content ul { @@apply list-disc; }
    .markdown-content ol { @@apply list-decimal; }
</style>
