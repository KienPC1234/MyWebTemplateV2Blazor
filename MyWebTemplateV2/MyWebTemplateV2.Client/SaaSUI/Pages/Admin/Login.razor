@page "/admin/login"
@layout Layout.MainLayout
@inject Services.AuthService Auth
@inject NavigationManager Nav
@using MyWebTemplateV2.Client.SaaSUI.Components

<PageTitle>Đăng nhập Quản trị | Nhịp đập</PageTitle>

<section class="min-h-screen flex items-center justify-center bg-zinc-50 relative overflow-hidden py-20">
    <!-- Decorative background -->
    <div class="absolute top-0 left-0 w-full h-full z-0 opacity-40 pointer-events-none">
        <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-fpt-orange/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-fpt-blue/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="w-full max-w-lg relative z-10 px-6">
        <div class="bg-white border border-zinc-100 p-12 md:p-16 shadow-3xl rounded-[3rem] relative overflow-hidden">
            <!-- Top accent bar -->
            <div class="absolute top-0 left-0 w-full h-3 flex">
                <div class="flex-1 bg-fpt-orange"></div>
                <div class="flex-1 bg-fpt-green"></div>
                <div class="flex-1 bg-fpt-blue"></div>
            </div>

            <!-- Brand logo -->
            <div class="flex flex-col items-center mb-12 text-center">
                <div class="w-20 h-20 bg-fpt-blue text-white rounded-[2rem] flex items-center justify-center shadow-2xl shadow-fpt-blue/20 mb-6 group hover:rotate-12 transition-transform">
                     <i class="bi bi-shield-lock text-4xl"></i>
                </div>
                <h2 class="text-3xl font-black text-fpt-blue uppercase italic tracking-tighter">Hệ thống <span class="text-fpt-orange">Quản trị</span></h2>
                <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mt-3">Secure Access Portal</p>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="bg-red-50 border border-red-100 p-6 rounded-3xl mb-8 flex items-start gap-4">
                    <i class="bi bi-exclamation-triangle-fill text-red-500 text-lg mt-0.5"></i>
                    <div>
                        <h4 class="text-[10px] font-black text-red-600 uppercase tracking-widest mb-1">Lỗi đăng nhập</h4>
                        <p class="text-xs font-bold text-red-500/80 leading-relaxed">@_error</p>
                    </div>
                </div>
            }

            <div class="space-y-8">
                <FptInput Label="Username" @bind-Value="_username" Placeholder="Admin username..." BootstrapIcon="person">
                </FptInput>
                
                <FptInput Label="Password" @bind-Value="_password" Type="password" OnKeyUp="HandleKeyUp" Placeholder="••••••••" BootstrapIcon="lock">
                </FptInput>
                
                <div class="pt-4">
                    <FptButton OnClick="HandleLogin" Disabled="@_isLoggingIn" Class="w-full py-5 text-sm">
                        @if (_isLoggingIn)
                        {
                            <Spinner />
                            <span>Đang xác thực...</span>
                        }
                        else
                        {
                            <span>Xác nhận truy cập</span>
                            <i class="bi bi-arrow-right ms-2"></i>
                        }
                    </FptButton>
                </div>
                
                <div class="flex justify-between items-center pt-8 border-t border-zinc-50">
                    <button @onclick='() => Nav.NavigateTo("/")' class="text-[10px] font-black uppercase tracking-widest text-zinc-400 hover:text-fpt-blue flex items-center gap-2">
                        <i class="bi bi-chevron-left"></i> Quay lại trang chủ
                    </button>
                    <span class="text-[10px] font-black text-zinc-300 uppercase">Nexus v3.2</span>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private string _username = "";
    private string _password = "";
    private string? _error;
    private bool _isLoggingIn;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/admin/dashboard");
        }
    }

    [Inject] IJSRuntime Js { get; set; } = default!;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleLogin();
        }
    }

    private async Task HandleLogin()
    {
        if (_isLoggingIn) return;

        _error = null;
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Vui lòng nhập đầy đủ tài khoản và mật khẩu.";
            return;
        }

        _isLoggingIn = true;
        try
        {
            var success = await Auth.VerifyAdminAsync(_username, _password);
            if (success)
            {
                Nav.NavigateTo("/admin/dashboard");
            }
            else
            {
                _error = "Thông tin đăng nhập không hợp lệ. Vui lòng kiểm tra lại.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Lỗi hệ thống: {ex.Message}";
        }
        finally
        {
            _isLoggingIn = false;
        }
    }
}
