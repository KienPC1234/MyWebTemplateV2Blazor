@page "/admin/dashboard"
@layout MyWebTemplateV2.Client.SaaSUI.Layout.AdminLayout
@inject HttpClient Http
@inject ISnackbar Snackbar
@using MudBlazor
@using MyWebTemplateV2.Client.Models
@using System.Net.Http.Headers
@using MyWebTemplateV2.Client.Services
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@using ApexCharts

<MudText Typo="Typo.h4" Class="mb-4">Dashboard Quản trị</MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6">Tổng số Bài thi</MudText>
            <MudText Typo="Typo.h3" Color="MudBlazor.Color.Primary">@(_submissions?.Count ?? 0)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6">Tổng số Ấn phẩm</MudText>
            <MudText Typo="Typo.h3" Color="MudBlazor.Color.Secondary">@(_publications?.Count ?? 0)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6">System Status</MudText>
            <MudChip T="string" Color="MudBlazor.Color.Success">Operational</MudChip>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mt-8">
    <MudTabPanel Text="Thống kê" Icon="@Icons.Material.Filled.BarChart">
        <MudGrid Class="pa-4">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-4">Bài thi theo môn học</MudText>
                    @if (_submissions != null)
                    {
                        <ApexChart TItem="Submission" Title="Số lượng bài thi">
                            <ApexPointSeries TItem="Submission"
                                             Items="_submissions"
                                             Name="Bài thi"
                                             SeriesType="SeriesType.Donut"
                                             XValue="@(e => e.Subject.ToString())"
                                             YValue="@(e => 1)"
                                             OrderByDescending="e => e.Y" />
                        </ApexChart>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-4">Top 5 bài thi được yêu thích</MudText>
                    @if (_submissions != null)
                    {
                        <ApexChart TItem="Submission" Title="Lượt thích">
                            <ApexPointSeries TItem="Submission"
                                             Items="_submissions.OrderByDescending(s => s.Votes?.Count ?? 0).Take(5).ToList()"
                                             Name="Lượt thích"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(e => e.Title)"
                                             YValue="@(e => e.Votes?.Count ?? 0)" />
                        </ApexChart>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
</MudTabs>



@code {
    private List<Publication>? _publications;
    private List<Submission>? _submissions;
    
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/admin/login");
            return;
        }
        
        if (Http.DefaultRequestHeaders.Authorization == null && Auth.Token != null)
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue(Auth.Token);
        }
        
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try {
            _publications = await Http.GetFromJsonAsync<List<Publication>>("/api/publications");
            _submissions = await Http.GetFromJsonAsync<List<Submission>>("/api/submissions");
        } catch (Exception ex) {
            Snackbar.Add($"Lỗi tải dữ liệu: {ex.Message}", Severity.Error);
        }
        _loading = false;
    }
}
