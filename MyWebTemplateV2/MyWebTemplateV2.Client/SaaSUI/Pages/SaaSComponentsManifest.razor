@page "/ui-kit"
@using MyWebTemplateV2.Components.UI.Group1_Layout
@using MyWebTemplateV2.Components.UI.Group2_Actions
@using MyWebTemplateV2.Components.UI.Group3_DataDisplay
@using MyWebTemplateV2.Components.UI.Group4_Forms
@using MyWebTemplateV2.Components.UI.Group5_Overlays
@using MyWebTemplateV2.Components.UI.Group7_Specialized
@using MyWebTemplateV2.Components.UI.Group9_AI

<PageTitle>UI Kit | Zinc Monochrome SaaS</PageTitle>

<div class="px-6 lg:px-12 py-20 max-w-7xl mx-auto space-y-24">
        
    <!-- Header -->
    <header class="space-y-4 max-w-2xl">
        <StatusBadge Status="active">SaaS UI Kit v1.0</StatusBadge>
        <h1 class="text-6xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 uppercase italic">
            Zinc Monochrome
        </h1>
        <p class="text-lg text-zinc-500 font-medium">
            High-end, minimalist component system for Blazor. Powered by Glassmorphism and Monochrome aesthetics.
        </p>
    </header>

    <!-- Group 1: Layout -->
    <section class="space-y-8">
        <div class="border-b border-zinc-200 dark:border-zinc-800 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">🏗️ Group 1: Layout & Scaffolding</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <Card>
                <Header>
                    <h3 class="text-sm font-bold uppercase tracking-wider">Glass Navbar & Shell</h3>
                </Header>
                <ChildContent>
                    <div class="p-12 bg-zinc-100 dark:bg-zinc-900 rounded-2xl relative overflow-hidden h-40 flex items-center justify-center">
                         <span class="text-xs text-zinc-400 italic">SaaSMainShell Container with Noise Overlay Rendering...</span>
                    </div>
                    <p class="mt-4 text-xs text-zinc-500 font-medium italic">All pages are wrapped in SaaSMainShell for consistent grainy-noise and light-tracking effects.</p>
                </ChildContent>
            </Card>
        </div>
    </section>

    <!-- Group 2: Actions -->
    <section class="space-y-8 text-zinc-900 dark:text-zinc-100">
        <div class="border-b border-zinc-200 dark:border-zinc-800 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">🔘 Group 2: Actions & Triggers</h2>
        </div>
        
        <div class="flex flex-wrap gap-4 items-center">
            <SaaSButton Variant="primary">Primary Action</SaaSButton>
            <SaaSButton Variant="secondary">Secondary Action</SaaSButton>
            <SaaSButton Variant="ghost">Ghost Trigger</SaaSButton>
            <SaaSButton Variant="primary">Processing...</SaaSButton>
        </div>
    </section>

    <!-- Group 3: Data Display -->
    <section class="space-y-8">
        <div class="border-b border-zinc-200 dark:border-zinc-800 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">📊 Group 3: Data Display</h2>
        </div>
        
        <div class="flex flex-wrap gap-6 items-center">
            <StatusBadge Status="active">Active Performance</StatusBadge>
            <StatusBadge Status="inactive">System Offline</StatusBadge>
        </div>
    </section>

    <!-- Group 4: Forms & Inputs -->
    <section class="space-y-8">
        <div class="border-b border-zinc-200 dark:border-zinc-800 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">📝 Group 4: Forms & Inputs</h2>
        </div>
        
        <div class="max-w-md space-y-4">
            <div>
               <FieldLabel>Organization Endpoint</FieldLabel>
               <MinimalInput Placeholder="https://api.your-saas.com" Value="https://api.antigravity.io" />
            </div>
            <div>
               <FieldLabel>Security Secret</FieldLabel>
               <MinimalInput Type="password" Placeholder="Enter token..." />
            </div>
        </div>
    </section>

    <!-- Group 5: Overlays -->
    <section class="space-y-8">
        <div class="border-b border-zinc-200 dark:border-zinc-800 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">🌫️ Group 5: Overlays & Feedback</h2>
        </div>
        
        <SaaSButton Variant="secondary" OnClick="() => isModalOpen = true">Open Glass Modal</SaaSButton>
        
        <GlassModal IsOpen="@isModalOpen" IsOpenChanged="@((v) => isModalOpen = v)">
            <Header>
               <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">Confirm Migration</h2>
            </Header>
            <ChildContent>
               <p class="leading-relaxed">This action will move all your cluster data to the new Zinc regions. This might take up to 2 hours.</p>
            </ChildContent>
            <Footer>
               <SaaSButton Variant="ghost" OnClick="() => isModalOpen = false">Cancel</SaaSButton>
               <SaaSButton Variant="primary" OnClick="() => isModalOpen = false">Start Migration</SaaSButton>
            </Footer>
        </GlassModal>
    </section>

    <!-- Group 9: AI Agents -->
    <section class="space-y-8">
        <div class="border-b border-zinc-200 dark:border-zinc-800 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">🧠 Group 9: AI & Intelligent Agents</h2>
        </div>
        
        <div class="py-12 px-8 bg-zinc-100 dark:bg-zinc-900 rounded-3xl border border-zinc-200/50 dark:border-zinc-800/50 overflow-hidden relative">
            <!-- Decorative Glow Behind AI Console -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-64 w-96 bg-zinc-400/20 dark:bg-zinc-100/5 blur-[100px] rounded-full"></div>
            
            <AIPromptConsole OnSubmit="HandleAIRequest" />
            
            @if (aiThinking)
            {
                <div class="mt-8 text-center animate-pulse-slow">
                    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">AI AGENT THINKING...</span>
                </div>
            }
        </div>
    </section>

    <!-- Specialized Snippets -->
    <section class="space-y-8">
        <div class="border-b border-zinc-200 dark:border-zinc-800 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">🧩 Group 7: Specialized Identity</h2>
        </div>
        
        <div class="max-w-xs p-4 glass rounded-2xl">
            <UserSnippet Name="Kien Phan" Email="developer@antigravity.io" />
            <hr class="my-3 border-zinc-200/50 dark:border-zinc-800/50" />
            <div class="flex flex-col gap-1 px-1">
                <button class="text-left py-1 text-[11px] font-bold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">ACCOUNT SETTINGS</button>
                <button class="text-left py-1 text-[11px] font-bold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">SECURITY & KEYS</button>
                <button class="text-left py-1 text-[11px] font-bold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">LOGOUT (⌘L)</button>
            </div>
        </div>
    </section>

</div>

@code {
    private bool isModalOpen = false;
    private bool aiThinking = false;

    private async Task HandleAIRequest(string prompt)
    {
        aiThinking = true;
        await Task.Delay(2500);
        aiThinking = false;
    }
}
