@page "/"
@using NeoUI.Blazor
@using NeoUI.Blazor.Charts
@using NeoUI.Icons.Lucide
@inject IToastService ToastService

<PageTitle>Nexus — Nền tảng phân tích thông minh</PageTitle>

<!-- ==========================================
     HERO SECTION
  ========================================== -->
<section class="hero-section">
    <!-- Status badge -->
    <div class="hero-badge-pill">
        <span class="hero-badge-dot"></span>
        Phiên bản mới v4.0 đã ra mắt — Xem ngay
        <LucideIcon Name="arrow-right" Class="h-3 w-3" />
    </div>

    <!-- Headline -->
    <h1 class="hero-title">
        Khai phá sức mạnh<br />
        <span class="hero-title-accent">dữ liệu thông minh.</span>
    </h1>

    <p class="hero-description">
        Nexus là nền tảng phân tích hiện đại dành cho doanh nghiệp. 
        Tự động hóa quy trình, trực quan hóa dữ liệu và đưa ra quyết định chính xác hơn — ngay từ hôm nay.
    </p>

    <!-- CTAs -->
    <div class="hero-actions">
        <Button Size="ButtonSize.Default" class="rounded-full px-8 py-5 font-bold" OnClick="@ShowWelcomeToast">
            <LucideIcon Name="rocket" Class="mr-2 h-4 w-4" />
            Dùng thử miễn phí
        </Button>
        <Dialog>
            <DialogTrigger AsChild>
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Default" class="rounded-full px-8 py-5 font-bold">
                    <LucideIcon Name="play-circle" Class="mr-2 h-4 w-4" />
                    Xem demo
                </Button>
            </DialogTrigger>
            <DialogContent class="sm:max-w-xl">
                <DialogHeader>
                    <DialogTitle>Demo nền tảng Nexus</DialogTitle>
                    <DialogDescription>
                        Khám phá các tính năng nổi bật của Nexus qua video demo tương tác dưới đây.
                    </DialogDescription>
                </DialogHeader>
                <div class="grid grid-cols-2 gap-4 py-4">
                    <Card class="cursor-pointer hover:border-primary transition-colors">
                        <CardContent class="pt-5 flex flex-col items-center gap-2 text-center">
                            <LucideIcon Name="bar-chart-3" Class="h-8 w-8 text-primary" />
                            <CardTitle class="text-sm">Analytics</CardTitle>
                            <CardDescription>Dashboard thời gian thực</CardDescription>
                        </CardContent>
                    </Card>
                    <Card class="cursor-pointer hover:border-primary transition-colors">
                        <CardContent class="pt-5 flex flex-col items-center gap-2 text-center">
                            <LucideIcon Name="cpu" Class="h-8 w-8 text-primary" />
                            <CardTitle class="text-sm">AI Engine</CardTitle>
                            <CardDescription>Dự báo thông minh</CardDescription>
                        </CardContent>
                    </Card>
                    <Card class="cursor-pointer hover:border-primary transition-colors">
                        <CardContent class="pt-5 flex flex-col items-center gap-2 text-center">
                            <LucideIcon Name="workflow" Class="h-8 w-8 text-primary" />
                            <CardTitle class="text-sm">Pipelines</CardTitle>
                            <CardDescription>Tự động hóa luồng dữ liệu</CardDescription>
                        </CardContent>
                    </Card>
                    <Card class="cursor-pointer hover:border-primary transition-colors">
                        <CardContent class="pt-5 flex flex-col items-center gap-2 text-center">
                            <LucideIcon Name="shield-check" Class="h-8 w-8 text-primary" />
                            <CardTitle class="text-sm">Bảo mật</CardTitle>
                            <CardDescription>Mã hóa end-to-end</CardDescription>
                        </CardContent>
                    </Card>
                </div>
                <DialogFooter>
                    <Button Variant="ButtonVariant.Default" class="rounded-full px-6">Đặt lịch tư vấn</Button>
                </DialogFooter>
            </DialogContent>
        </Dialog>
    </div>

    <!-- Stats Row -->
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-4">
        <div class="stat-box">
            <div class="stat-box-num">10,000+</div>
            <div class="stat-box-label">Doanh nghiệp</div>
        </div>
        <Separator Orientation="SeparatorOrientation.Vertical" Class="h-12 hidden md:block" />
        <div class="stat-box">
            <div class="stat-box-num">99.9%</div>
            <div class="stat-box-label">Uptime SLA</div>
        </div>
        <Separator Orientation="SeparatorOrientation.Vertical" Class="h-12 hidden md:block" />
        <div class="stat-box">
            <div class="stat-box-num">50M+</div>
            <div class="stat-box-label">Sự kiện / giây</div>
        </div>
        <Separator Orientation="SeparatorOrientation.Vertical" Class="h-12 hidden md:block" />
        <div class="stat-box">
            <div class="stat-box-num">12ms</div>
            <div class="stat-box-label">Độ trễ trung bình</div>
        </div>
    </div>
</section>

<!-- ==========================================
     DASHBOARD SHOWCASE
  ========================================== -->
<section class="showcase-container">
    <div class="showcase-shadow"></div>
    <div class="showcase-frame">
        <div class="showcase-topline"></div>
        <img src="/images/dashboard_mockup.png" alt="Nexus Analytics Dashboard" />
    </div>
</section>

<!-- ==========================================
     ALERTS / NOTIFICATIONS DEMO
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="bell" Class="h-3 w-3" />
            Hệ thống thông báo
        </div>
        <h2 class="section-title">Thông tin luôn rõ ràng</h2>
        <p class="section-subtitle">NeoUI Alert component giúp người dùng không bỏ lỡ thông tin quan trọng nào.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        <Alert Variant="AlertVariant.Info" class="rounded-2xl">
            <Icon><LucideIcon Name="info" Size="16" /></Icon>
            <ChildContent>
                <AlertTitle>Đã cập nhật dữ liệu</AlertTitle>
                <AlertDescription>Pipeline đã xử lý xong 1,243 bản ghi mới.</AlertDescription>
            </ChildContent>
        </Alert>
        <Alert Variant="AlertVariant.Success" class="rounded-2xl">
            <Icon><LucideIcon Name="check-circle" Size="16" /></Icon>
            <ChildContent>
                <AlertTitle>Đồng bộ thành công</AlertTitle>
                <AlertDescription>Toàn bộ dữ liệu đã được chuẩn hóa và lưu trữ.</AlertDescription>
            </ChildContent>
        </Alert>
        <Alert Variant="AlertVariant.Warning" class="rounded-2xl">
            <Icon><LucideIcon Name="triangle-alert" Size="16" /></Icon>
            <ChildContent>
                <AlertTitle>Cảnh báo dung lượng</AlertTitle>
                <AlertDescription>Kho dữ liệu đang dùng 85% dung lượng cho phép.</AlertDescription>
            </ChildContent>
        </Alert>
        <Alert Variant="AlertVariant.Destructive" class="rounded-2xl">
            <Icon><LucideIcon Name="x-circle" Size="16" /></Icon>
            <ChildContent>
                <AlertTitle>Kết nối bị gián đoạn</AlertTitle>
                <AlertDescription>Nguồn dữ liệu API-07 không phản hồi. Đang thử lại…</AlertDescription>
            </ChildContent>
        </Alert>
    </div>
</section>

<!-- ==========================================
     FEATURES TABS
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="layers" Class="h-3 w-3" />
            Tính năng nổi bật
        </div>
        <h2 class="section-title">Mọi thứ bạn cần</h2>
        <p class="section-subtitle">Nexus tích hợp đầy đủ công cụ để vận hành dữ liệu mượt mà từ đầu đến cuối.</p>
    </div>

    <Tabs DefaultValue="analytics" class="max-w-4xl mx-auto">
        <TabsList class="grid w-full grid-cols-3 rounded-full">
            <TabsTrigger Value="analytics">Analytics</TabsTrigger>
            <TabsTrigger Value="pipelines">Pipelines</TabsTrigger>
            <TabsTrigger Value="security">Bảo mật</TabsTrigger>
        </TabsList>
        <TabsContent Value="analytics" class="mt-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="bar-chart-3" Class="h-6 w-6" />
                        </div>
                        <CardTitle>Dashboard thời gian thực</CardTitle>
                        <CardDescription>Dữ liệu cập nhật liên tục, không cần tải lại trang.</CardDescription>
                    </CardHeader>
                </Card>
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="filter" Class="h-6 w-6" />
                        </div>
                        <CardTitle>Bộ lọc thông minh</CardTitle>
                        <CardDescription>Phân tích sâu từng chiều dữ liệu với drag-and-drop.</CardDescription>
                    </CardHeader>
                </Card>
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="download" Class="h-6 w-6" />
                        </div>
                        <CardTitle>Xuất báo cáo</CardTitle>
                        <CardDescription>Tự động gửi báo cáo PDF, Excel theo lịch định sẵn.</CardDescription>
                    </CardHeader>
                </Card>
            </div>
        </TabsContent>
        <TabsContent Value="pipelines" class="mt-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="workflow" Class="h-6 w-6" />
                        </div>
                        <CardTitle>Visual Builder</CardTitle>
                        <CardDescription>Kéo thả để xây dựng pipeline phức tạp trong vài phút.</CardDescription>
                    </CardHeader>
                </Card>
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="plug" Class="h-6 w-6" />
                        </div>
                        <CardTitle>200+ Connectors</CardTitle>
                        <CardDescription>Kết nối với mọi nguồn dữ liệu phổ biến ngay lập tức.</CardDescription>
                    </CardHeader>
                </Card>
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="timer" Class="h-6 w-6" />
                        </div>
                        <CardTitle>Lập lịch tự động</CardTitle>
                        <CardDescription>Chạy pipeline theo lịch cron hoặc sự kiện trigger.</CardDescription>
                    </CardHeader>
                </Card>
            </div>
        </TabsContent>
        <TabsContent Value="security" class="mt-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="lock" Class="h-6 w-6" />
                        </div>
                        <CardTitle>Mã hóa AES-256</CardTitle>
                        <CardDescription>Dữ liệu được mã hóa hoàn toàn khi truyền và lưu trữ.</CardDescription>
                    </CardHeader>
                </Card>
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="users" Class="h-6 w-6" />
                        </div>
                        <CardTitle>Phân quyền chi tiết</CardTitle>
                        <CardDescription>RBAC đến từng trường dữ liệu, audit log đầy đủ.</CardDescription>
                    </CardHeader>
                </Card>
                <Card>
                    <CardHeader>
                        <div class="feature-icon-wrap">
                            <LucideIcon Name="shield-check" Class="h-6 w-6" />
                        </div>
                        <CardTitle>SOC 2 Type II</CardTitle>
                        <CardDescription>Tuân thủ đầy đủ tiêu chuẩn bảo mật quốc tế.</CardDescription>
                    </CardHeader>
                </Card>
            </div>
        </TabsContent>
    </Tabs>
</section>

<!-- ==========================================
     ACCORDION FAQ
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="help-circle" Class="h-3 w-3" />
            Câu hỏi thường gặp
        </div>
        <h2 class="section-title">Giải đáp thắc mắc</h2>
    </div>

    <div class="max-w-2xl mx-auto">
        <Accordion Type="AccordionType.Single" Collapsible="true">
            <AccordionItem Value="q1">
                <AccordionTrigger>Nexus có phù hợp cho doanh nghiệp vừa và nhỏ không?</AccordionTrigger>
                <AccordionContent>
                    Hoàn toàn phù hợp! Nexus được thiết kế linh hoạt, từ startup đến tập đoàn lớn đều có thể sử dụng hiệu quả. Gói Starter chỉ từ $29/tháng.
                </AccordionContent>
            </AccordionItem>
            <AccordionItem Value="q2">
                <AccordionTrigger>Tôi có thể tích hợp Nexus với hệ thống sẵn có không?</AccordionTrigger>
                <AccordionContent>
                    Có. Nexus cung cấp REST API, webhooks và 200+ connector có sẵn cho các hệ thống phổ biến như Salesforce, Google Sheets, PostgreSQL, MySQL, BigQuery và nhiều hơn nữa.
                </AccordionContent>
            </AccordionItem>
            <AccordionItem Value="q3">
                <AccordionTrigger>Dữ liệu của tôi có được bảo mật không?</AccordionTrigger>
                <AccordionContent>
                    Bảo mật là ưu tiên hàng đầu. Mọi dữ liệu được mã hóa AES-256, hạ tầng đạt chuẩn SOC 2 Type II, và bạn có toàn quyền kiểm soát phân quyền truy cập.
                </AccordionContent>
            </AccordionItem>
            <AccordionItem Value="q4">
                <AccordionTrigger>Có hỗ trợ tiếng Việt không?</AccordionTrigger>
                <AccordionContent>
                    Có! Nexus hỗ trợ đa ngôn ngữ bao gồm tiếng Việt. Đội ngũ hỗ trợ khách hàng tiếng Việt hoạt động 24/7.
                </AccordionContent>
            </AccordionItem>
        </Accordion>
    </div>
</section>

<!-- ==========================================
     PROGRESS / ONBOARDING
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="trending-up" Class="h-3 w-3" />
            Hiệu suất hệ thống
        </div>
        <h2 class="section-title">Trạng thái thời gian thực</h2>
    </div>

    <Card class="max-w-2xl mx-auto">
        <CardHeader>
            <CardTitle>System Health</CardTitle>
            <CardDescription>Các chỉ số hiệu suất đang được theo dõi liên tục.</CardDescription>
        </CardHeader>
        <CardContent class="space-y-5">
            <div>
                <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium">CPU Usage</span>
                    <span class="text-muted-foreground">42%</span>
                </div>
                <Progress Value="42" Max="100" Class="h-2" />
            </div>
            <div>
                <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium">RAM Usage</span>
                    <span class="text-muted-foreground">67%</span>
                </div>
                <Progress Value="67" Max="100" Class="h-2" />
            </div>
            <div>
                <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium">Storage</span>
                    <span class="text-muted-foreground">85%</span>
                </div>
                <Progress Value="85" Max="100" Class="h-2" />
            </div>
            <div>
                <div class="flex justify-between text-sm mb-1.5">
                    <span class="font-medium">Network Throughput</span>
                    <span class="text-muted-foreground">23%</span>
                </div>
                <Progress Value="23" Max="100" Class="h-2" />
            </div>
        </CardContent>
    </Card>
</section>

<!-- ==========================================
     TESTIMONIALS
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="star" Class="h-3 w-3" />
            Phản hồi khách hàng
        </div>
        <h2 class="section-title">Được tin dùng bởi hàng nghìn công ty</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="testimonial-card">
            <div class="testimonial-quote">"</div>
            <div class="flex items-center gap-1 mb-4">
                @for (int i = 0; i < 5; i++)
                {
                    <LucideIcon Name="star" Class="h-4 w-4 text-primary fill-current" />
                }
            </div>
            <p class="text-sm leading-relaxed text-muted-foreground mb-5">
                Nexus thay đổi hoàn toàn cách chúng tôi theo dõi doanh thu. Dashboard real-time giúp team ra quyết định nhanh gấp 3 lần.
            </p>
            <div class="flex items-center gap-3">
                <Avatar>
                    <AvatarFallback>AT</AvatarFallback>
                </Avatar>
                <div>
                    <div class="font-semibold text-sm">Anh Tuấn</div>
                    <div class="text-xs text-muted-foreground">CTO, VinaCommerce</div>
                </div>
            </div>
        </div>

        <div class="testimonial-card" style="border-color: oklch(var(--primary)); box-shadow: 0 8px 32px oklch(var(--primary) / 0.15);">
            <div class="testimonial-quote">"</div>
            <Badge Variant="BadgeVariant.Default" class="mb-4">Nổi bật</Badge>
            <div class="flex items-center gap-1 mb-4">
                @for (int i = 0; i < 5; i++)
                {
                    <LucideIcon Name="star" Class="h-4 w-4 text-primary fill-current" />
                }
            </div>
            <p class="text-sm leading-relaxed text-muted-foreground mb-5">
                Tích hợp với hệ thống ERP cũ của chúng tôi chỉ mất 2 ngày. Đội ngũ support của Nexus cực kỳ chuyên nghiệp và nhanh nhạy.
            </p>
            <div class="flex items-center gap-3">
                <Avatar>
                    <AvatarFallback>ML</AvatarFallback>
                </Avatar>
                <div>
                    <div class="font-semibold text-sm">Mai Linh</div>
                    <div class="text-xs text-muted-foreground">Head of Data, TechViet Corp</div>
                </div>
            </div>
        </div>

        <div class="testimonial-card">
            <div class="testimonial-quote">"</div>
            <div class="flex items-center gap-1 mb-4">
                @for (int i = 0; i < 5; i++)
                {
                    <LucideIcon Name="star" Class="h-4 w-4 text-primary fill-current" />
                }
            </div>
            <p class="text-sm leading-relaxed text-muted-foreground mb-5">
                Chi phí phân tích dữ liệu giảm 60% sau khi chuyển sang Nexus. Tự động hóa hoàn toàn thay thế 3 nhân sự làm báo cáo thủ công.
            </p>
            <div class="flex items-center gap-3">
                <Avatar>
                    <AvatarFallback>HD</AvatarFallback>
                </Avatar>
                <div>
                    <div class="font-semibold text-sm">Hoàng Dũng</div>
                    <div class="text-xs text-muted-foreground">CEO, SmartRetail VN</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ==========================================
     PRICING CARDS
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="tag" Class="h-3 w-3" />
            Bảng giá
        </div>
        <h2 class="section-title">Minh bạch, không phí ẩn</h2>
        <p class="section-subtitle">Chọn gói phù hợp với nhu cầu doanh nghiệp của bạn.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Starter -->
        <div class="pricing-card">
            <Badge Variant="BadgeVariant.Secondary" class="mb-4">Starter</Badge>
            <div class="pricing-price mb-2">$29<span class="text-lg font-normal text-muted-foreground">/tháng</span></div>
            <p class="text-sm text-muted-foreground mb-6">Phù hợp cho đội nhỏ bắt đầu với dữ liệu.</p>
            <Separator class="mb-6" />
            <ul class="space-y-3 text-sm text-muted-foreground mb-8">
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> 5 người dùng</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> 10 pipelines</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> 50GB lưu trữ</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> Email support</li>
            </ul>
            <Button Variant="ButtonVariant.Outline" class="w-full rounded-full">Bắt đầu miễn phí</Button>
        </div>

        <!-- Pro (Popular) -->
        <div class="pricing-card pricing-card-popular">
            <div class="flex items-center gap-2 mb-4">
                <Badge Variant="BadgeVariant.Default">Pro</Badge>
                <Badge Variant="BadgeVariant.Secondary">Phổ biến nhất</Badge>
            </div>
            <div class="pricing-price mb-2">$99<span class="text-lg font-normal text-muted-foreground">/tháng</span></div>
            <p class="text-sm text-muted-foreground mb-6">Cho đội growing với nhu cầu phân tích nghiêm túc.</p>
            <Separator class="mb-6" />
            <ul class="space-y-3 text-sm text-muted-foreground mb-8">
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> 25 người dùng</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> Unlimited pipelines</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> 500GB lưu trữ</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> Priority support 24/7</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> AI Predictions</li>
            </ul>
            <Button class="w-full rounded-full" OnClick="@ShowProToast">Nâng cấp lên Pro</Button>
        </div>

        <!-- Enterprise -->
        <div class="pricing-card">
            <Badge Variant="BadgeVariant.Outline" class="mb-4">Enterprise</Badge>
            <div class="pricing-price mb-2">Custom<span class="text-lg font-normal text-muted-foreground"></span></div>
            <p class="text-sm text-muted-foreground mb-6">Giải pháp tùy chỉnh cho tập đoàn lớn.</p>
            <Separator class="mb-6" />
            <ul class="space-y-3 text-sm text-muted-foreground mb-8">
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> Unlimited users</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> On-premise / Private Cloud</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> SSO / LDAP integration</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> SLA 99.99%</li>
                <li class="flex items-center gap-2"><LucideIcon Name="check" Class="h-4 w-4 text-primary shrink-0" /> Dedicated CSM</li>
