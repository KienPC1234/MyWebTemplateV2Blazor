    <div class="cta-banner">
        <div class="cta-banner-noise"></div>
        <div class="relative z-10">
            <Badge Variant="BadgeVariant.Secondary" class="mb-6">Bắt đầu hôm nay</Badge>
            <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-4" style="font-family:'Plus Jakarta Sans',sans-serif;">
                Sẵn sàng để tăng trưởng?
            </h2>
            <p class="text-lg text-white/80 max-w-xl mx-auto mb-10">
