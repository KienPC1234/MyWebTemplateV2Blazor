@page "/"
@using MyWebTemplateV2.Client.Models
@using MyWebTemplateV2.Client.SaaSUI.Components
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Trang chủ | FPT Education</PageTitle>

<!-- HERO ENGINE: HIGH-END VISUALS -->
<section class="relative min-h-[95vh] flex items-center overflow-hidden bg-white pt-24 pb-32">
    <!-- Advanced Mesh Background -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-fpt-orange/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 animate-fpt-pulse"></div>
        <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-fpt-blue/5 rounded-full blur-[100px] translate-y-1/4 -translate-x-1/4"></div>
        <div class="absolute inset-0 opacity-[0.4]" style="background-image: radial-gradient(circle at 2px 2px, #f1f1f1 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10">
        <!-- Content Column -->
        <div class="lg:col-span-7 flex flex-col items-start" data-aos="fade-right">
            <div class="group inline-flex items-center gap-4 px-6 py-2 bg-white border border-zinc-200 rounded-full shadow-xl shadow-zinc-200/50 mb-12 hover:border-fpt-orange transition-all duration-500">
                <div class="w-2 h-2 rounded-full bg-fpt-orange animate-pulse"></div>
                <span class="text-[10px] font-black uppercase  text-zinc-500 group-hover:text-fpt-orange transition-colors">FPT Extracurricular 2026</span>
            </div>
            
            <h1 class="text-7xl md:text-8xl lg:text-[110px] font-black text-fpt-blue uppercase  leading-[0.85] mb-10">
                Nhịp đập <br />
                <span class="text-fpt-orange italic relative inline-block">
                    Sáng tạo
                    <svg class="absolute -bottom-6 left-0 w-full h-8 text-fpt-green/20 -z-10" viewBox="0 0 100 10" preserveAspectRatio="none">
                        <path d="M0 5 Q 25 0 50 5 T 100 5" stroke="currentColor" stroke-width="12" fill="none" />
                    </svg>
                </span>
            </h1>
            
            <p class="text-xl md:text-2xl text-zinc-400 mb-14 max-w-xl leading-relaxed font-medium">
                Nền tảng kết nối <span class="text-fpt-blue font-bold italic">đam mê</span>, khơi nguồn <span class="text-fpt-green font-bold">tri thức</span>. Nơi mỗi học sinh FPT đều là một nghệ sĩ, một nhà kiến tạo tương lai.
            </p>
            
            <div class="flex flex-wrap gap-8">
                <FptButton OnClick='() => Nav.NavigateTo("/ngoai-khoa")'>
                    <span>Khám phá ngay</span>
                    <LucideIcon Name="ArrowUpRight" Size="18" />
                </FptButton>
                <FptButton Variant="secondary" OnClick="() => _showSubmitModal = true">
                    <span>Gửi bài sáng tác</span>
                </FptButton>
            </div>
            
            <!-- Trust Indicators -->
            <div class="mt-20 flex items-center gap-10">
                <div class="flex -space-x-4">
                    @for (int i = 1; i <= 4; i++)
                    {
                        <div class="w-12 h-12 rounded-2xl border-4 border-white bg-zinc-100 flex items-center justify-center text-zinc-400 overflow-hidden shadow-md">
                            <LucideIcon Name="User" Size="20" />
                        </div>
                    }
                </div>
                <div>
                    <div class="text-xl font-black text-fpt-blue leading-none">1,200+</div>
                    <div class="text-[9px] font-black uppercase text-zinc-400  mt-1">Học sinh tham gia</div>
                </div>
            </div>
        </div>

        <!-- Visual Column -->
        <div class="lg:col-span-5 relative" data-aos="fade-left" data-aos-delay="200">
            <div class="relative aspect-[4/5] w-full">
                <!-- Abstract Stack -->
                <div class="absolute top-10 right-0 w-[90%] h-full bg-zinc-50 rounded-[3rem] border border-zinc-200 -rotate-3 transition-transform hover:rotate-0 duration-700"></div>
                <div class="absolute top-5 right-5 w-[90%] h-full bg-white rounded-[3rem] shadow-2xl shadow-zinc-200 border border-zinc-100 p-4 rotate-3 transition-transform hover:rotate-0 duration-700 overflow-hidden group">
                    <img src="images/dashboard_mockup.png" class="w-full h-full object-cover rounded-[2.5rem] group-hover:scale-105 transition-transform duration-1000" />
                    <div class="absolute inset-0 bg-gradient-to-t from-fpt-blue/40 to-transparent"></div>
                    
                    <!-- Floating Insight -->
                    <div class="absolute bottom-10 left-10 right-10 p-8 bg-white/90 backdrop-blur-xl rounded-[2rem] border border-white/50 shadow-2xl">
                        <div class="flex items-center gap-4 mb-3">
                            <div class="w-10 h-10 rounded-xl bg-fpt-orange/10 flex items-center justify-center text-fpt-orange">
                                <LucideIcon Name="Sparkles" Size="20" />
                            </div>
                            <span class="text-[10px] font-black uppercase  text-fpt-blue">Latest Insight</span>
                        </div>
                        <p class="text-sm font-bold text-zinc-500 leading-snug">
                            "Sáng tạo là hành trình tự do nhất của tâm hồn học sinh FPT."
                        </p>
                    </div>
                </div>

                <!-- Dynamic Badges -->
                <div class="absolute -top-10 -left-10 w-32 h-32 bg-fpt-green rounded-[2.5rem] flex flex-col items-center justify-center text-white shadow-2xl shadow-fpt-green/30 -rotate-12 animate-fpt-pulse">
                    <div class="text-3xl font-black leading-none">01</div>
                    <div class="text-[8px] font-black uppercase  mt-1">Ranking</div>
                </div>

                <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-fpt-orange rounded-full flex flex-col items-center justify-center text-white shadow-2xl shadow-fpt-orange/30 rotate-12">
                    <div class="text-4xl font-black italic  leading-none">HOT</div>
                    <div class="text-[8px] font-black uppercase  mt-1">Sáng tác 2026</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CONTENT SECTIONS (REFINED) -->
<section class="py-32 bg-zinc-50/50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-10">
            <div class="max-w-xl">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-8 h-1 bg-fpt-orange rounded-full"></div>
                    <span class="text-[10px] font-black uppercase  text-fpt-orange">Editorial Selection</span>
                </div>
                <h2 class="text-5xl md:text-6xl font-black text-fpt-blue uppercase italic ">Ấn phẩm <span class="text-fpt-orange">Nhái Bén</span></h2>
                <p class="text-zinc-400 mt-6 text-lg font-medium">Khám phá thế giới quan đa chiều qua những trang viết đầy cảm hứng.</p>
            </div>
            <button @onclick='() => Nav.NavigateTo("/mon-hoc/van")' class="group flex items-center gap-4 text-xs font-black uppercase  text-fpt-blue hover:text-fpt-orange transition-all">
                Xem tất cả ấn phẩm <LucideChevronRight Size="16" />
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            @if (_latestPublications == null)
            {
                @for (int i = 0; i < 3; i++)
                {
                    <div class="h-[500px] bg-white rounded-[3rem] animate-pulse"></div>
                }
            }
            else
            {
                @foreach (var pub in _latestPublications)
                {
                    <FptCard Variant="hover">
                        <div class="aspect-[4/5] bg-zinc-50 rounded-[2.5rem] relative overflow-hidden mb-8">
                            <img src="@pub.CoverImagePath" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" />
                            <div class="absolute inset-0 bg-fpt-blue/80 opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center gap-6">
                                <button @onclick="() => OpenPdf(pub.PdfPath)" class="w-16 h-16 bg-fpt-orange text-white rounded-full flex items-center justify-center hover:scale-110 shadow-2xl"><LucideIcon Name="Eye" Size="24" /></button>
                                <a href="@pub.PdfPath" download class="w-16 h-16 bg-white text-fpt-blue rounded-full flex items-center justify-center hover:scale-110 shadow-2xl"><LucideIcon Name="Download" Size="24" /></a>
                            </div>
                        </div>
                        <div class="px-6 pb-6 text-center">
                            <span class="text-[10px] font-black text-fpt-green uppercase  mb-2 block">Issue #@pub.Id</span>
                            <h4 class="text-2xl font-black text-fpt-blue uppercase leading-tight group-hover:text-fpt-orange transition-colors">@pub.Title</h4>
                            <div class="mt-4 flex items-center justify-center gap-2 text-[10px] font-bold text-zinc-400">
                                <LucideIcon Name="Calendar" Size="14" />
                                <span>@pub.CreatedAt.ToString("MMMM, yyyy")</span>
                            </div>
                        </div>
                    </FptCard>
                }
            }
        </div>
    </div>
</section>

<!-- SUBMISSION BOARD (REFINED) -->
<section class="py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <div class="bg-fpt-blue rounded-[4rem] p-12 lg:p-20 relative overflow-hidden">
            <!-- Background Decoration -->
            <div class="absolute top-0 right-0 w-1/2 h-full bg-white/5 skew-x-[15deg] translate-x-1/4"></div>
            
            <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="text-5xl lg:text-7xl font-black text-white uppercase italic  mb-8 leading-none">
                        Bảng tin <br /><span class="text-fpt-orange">Sáng tác</span>
                    </h2>
                    <p class="text-white/60 text-lg font-medium max-w-md leading-relaxed mb-12">
                        Theo dõi nhịp đập sáng tạo của học sinh FPT qua bảng tin cập nhật thời gian thực.
                    </p>
                    <FptButton Class="!bg-white !text-fpt-blue hover:!bg-fpt-orange hover:!text-white" OnClick="() => _showSubmitModal = true">
                        <span>Gửi tác phẩm mới</span>
                    </FptButton>
                </div>
                
                <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-[3rem] p-8 lg:p-12">
                    <div class="space-y-8">
                        @if (_submissions == null)
                        {
                            <div class="flex justify-center p-10"><Spinner /></div>
                        }
                        else
                        {
                            @foreach (var sub in _submissions.Take(4))
                            {
                                <div class="flex items-center justify-between border-b border-white/10 pb-6 last:border-0 last:pb-0 group">
                                    <div class="flex items-center gap-5">
                                        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-fpt-orange group-hover:bg-fpt-orange group-hover:text-white transition-all">
                                            <LucideIcon Name="Feather" Size="20" />
                                        </div>
                                        <div>
                                            <div class="text-white font-black uppercase text-sm group-hover:text-fpt-orange transition-colors">@sub.Title</div>
                                            <div class="text-white/40 text-[10px] font-bold mt-1 uppercase ">by @sub.Author</div>
                                        </div>
                                    </div>
                                    <button @onclick='() => Nav.NavigateTo($"/mon-hoc/van?id={sub.Id}")' class="text-[10px] font-black uppercase text-white hover:text-fpt-orange transition-colors ">Details</button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MODAL: GỬI BÀI (REFINED) -->
<FptModal IsOpen="_showSubmitModal" OnClose="() => _showSubmitModal = false" Title="Submit Your Art" Subtitle="Hệ thống gửi bài sáng tác FPT">
    <HeaderIcon>
        <LucideIcon Name="Send" Size="24" />
    </HeaderIcon>
    <ChildContent>
        <div class="space-y-10">
            @if (_isSuccess)
            {
                <div class="text-center py-12 space-y-8" data-aos="zoom-in">
                    <div class="w-24 h-24 bg-fpt-green text-white rounded-full flex items-center justify-center mx-auto shadow-2xl shadow-fpt-green/40">
                        <LucideIcon Name="CheckCircle" Size="40" />
                    </div>
                    <div>
                        <h4 class="text-3xl font-black text-fpt-blue uppercase italic">Gửi bài thành công!</h4>
                        <p class="text-zinc-500 mt-3 font-medium text-lg">Cảm ơn bạn đã đóng góp cho cộng đồng sáng tạo FPT Education.</p>
                    </div>
                    <FptButton OnClick="() => { _showSubmitModal = false; _isSuccess = false; }">Đóng cửa sổ</FptButton>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black uppercase text-zinc-400  ml-4">Full Name</label>
                        <input @bind="_newSubmission.Author" class="bg-zinc-50 border-2 border-transparent px-8 py-5 rounded-[2rem] text-sm font-bold text-zinc-800 outline-none transition-all duration-300 focus:border-fpt-orange focus:bg-white focus:shadow-xl focus:shadow-fpt-orange/5 w-full" placeholder="Nguyễn Văn A..." />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black uppercase text-zinc-400  ml-4">Title</label>
                        <input @bind="_newSubmission.Title" class="bg-zinc-50 border-2 border-transparent px-8 py-5 rounded-[2rem] text-sm font-bold text-zinc-800 outline-none transition-all duration-300 focus:border-fpt-orange focus:bg-white focus:shadow-xl focus:shadow-fpt-orange/5 w-full" placeholder="Tác phẩm của tôi..." />
                    </div>
                </div>
                <div class="space-y-3">
                    <label class="text-[10px] font-black uppercase text-zinc-400  ml-4">Content</label>
                    <textarea @bind="_newSubmission.Content" class="bg-zinc-50 border-2 border-transparent px-8 py-5 rounded-[2rem] text-sm font-bold text-zinc-800 outline-none transition-all duration-300 focus:border-fpt-orange focus:bg-white focus:shadow-xl focus:shadow-fpt-orange/5 w-full h-48 resize-none" placeholder="Viết nội dung tại đây..."></textarea>
                </div>
                
                <div class="flex items-center gap-6 p-8 bg-fpt-orange/5 rounded-[2rem] border border-fpt-orange/10 border-dashed">
                    <LucideIcon Name="Info" Size="24" Class="text-fpt-orange" />
                    <p class="text-[10px] font-bold text-zinc-500 uppercase leading-relaxed ">
                        Bài viết sẽ được duyệt bởi Ban biên tập trước khi đăng tải chính thức.
                    </p>
                </div>

                <FptButton OnClick="SubmitEntry" Disabled="@_isSubmitting" Class="w-full py-6">
                    @if (_isSubmitting) { <Spinner /> }
                    <span>Confirm Submission</span>
                </FptButton>
            }
        </div>
    </ChildContent>
</FptModal>

@code {
    private List<Publication>? _latestPublications;
    private List<Submission>? _submissions;
    private bool _showSubmitModal = false;
    private bool _isSubmitting = false;
    private bool _isSuccess = false;
    private Submission _newSubmission = new() { Author = "Học sinh FPT" };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            _latestPublications = await Http.GetFromJsonAsync<List<Publication>>("/api/publications");
            _submissions = await Http.GetFromJsonAsync<List<Submission>>("/api/submissions");
        }
        catch
        {
            _latestPublications ??= new();
            _submissions ??= new();
        }
    }

    private async Task SubmitEntry()
    {
        if (string.IsNullOrWhiteSpace(_newSubmission.Title) || string.IsNullOrWhiteSpace(_newSubmission.Content)) return;
        
        _isSubmitting = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/submissions", _newSubmission);
            if (response.IsSuccessStatusCode)
            {
                _isSuccess = true;
                _newSubmission = new() { Author = "Học sinh FPT" };
                await LoadData();
            }
        }
        catch { }
        finally { _isSubmitting = false; }
    }

    private void OpenPdf(string path) => Nav.NavigateTo(path, true);
}
