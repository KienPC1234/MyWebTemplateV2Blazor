@page "/"
@using NeoUI.Blazor
@using NeoUI.Blazor.Primitives
@using NeoUI.Icons.Lucide

<PageTitle>Nexus FPT | Hệ thống quản lý doanh nghiệp thông minh</PageTitle>


<!-- FPT Hero Section -->
<section class="fpt-hero">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="relative z-10">
            <div class="flex items-center gap-2 mb-8 animate-fade-in">
                <div class="w-8 h-[2px] bg-fpt-orange"></div>
                <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-fpt-orange">FPT Corporation | Branding v3.1</span>
            </div>
            
            <h1 class="hero-title animate-slide-up">
                Công nghệ <br />
                <span class="hero-highlight italic">Kiến tạo Hạnh phúc</span>
            </h1>
            
            <p class="text-base text-zinc-500 mb-10 max-w-xl leading-relaxed animate-slide-up" style="animation-delay: 0.1s">
                FPT Nexus là nền tảng quản trị thông minh, kế thừa tinh hoa hơn 30 năm phát triển của Tập đoàn. 
                Chúng tôi mang đến giải pháp công nghệ hiện đại, ổn định và bảo mật tối đa cho lộ trình chuyển đổi số của mọi doanh nghiệp.
            </p>
            
            <div class="flex flex-wrap gap-4 animate-slide-up" style="animation-delay: 0.2s">
                <button class="btn-fpt flex items-center gap-3">
                    Bắt đầu ngay <LucideIcon Name="arrow-right" class="w-4 h-4" />
                </button>
                <button class="btn-fpt-outline">Giải pháp doanh nghiệp</button>
            </div>
        </div>

        <!-- FPT Graphical Support Element (skewed orange block) -->
        <div class="relative hidden lg:flex items-center justify-center animate-fade-in" style="animation-delay: 0.3s">
            <div class="relative w-full max-w-lg aspect-square">
                <!-- Background Support Sign (skewed orange) -->
                <div class="absolute top-0 right-0 w-[80%] h-full bg-fpt-orange/5 -skew-x-[13deg] border-r-4 border-fpt-orange/20"></div>
                
                <!-- Floating Official Blocks -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="flex items-end gap-6">
                        <div class="w-16 h-48 bg-fpt-orange -skew-x-[13deg] shadow-lg animate-pulse-slow"></div>
                        <div class="w-16 h-64 bg-fpt-green -skew-x-[13deg] shadow-lg translate-y-8"></div>
                        <div class="w-16 h-56 bg-fpt-blue -skew-x-[13deg] shadow-lg translate-y-16"></div>
                    </div>
                </div>
                
                <!-- Decorative Elements -->
                <div class="absolute bottom-10 left-10 w-24 h-24 border border-zinc-200 -skew-x-[13deg]"></div>
            </div>
        </div>
    </div>
</section>

<!-- FPT Mission & Vision (New Section) -->
<section class="py-24 bg-white overflow-hidden relative border-t border-border">
    <!-- Large skewed text background "FPT" -->
    <div class="absolute -top-20 -right-20 text-[20rem] font-black italic text-zinc-50 opacity-[0.03] select-none pointer-events-none -skew-x-[13deg]">
        FPT
    </div>

    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div class="grid grid-cols-2 gap-4">
            <div class="p-8 bg-zinc-50 border-l-4 border-fpt-orange">
                <div class="text-3xl font-black text-fpt-blue mb-2 italic">01</div>
                <div class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4">Sứ mệnh</div>
                <p class="text-xs text-zinc-500 leading-relaxed">
                    Xây dựng hệ sinh thái công nghệ giúp doanh nghiệp vận hành linh hoạt và hiệu quả hơn.
                </p>
            </div>
            <div class="p-8 bg-zinc-50 border-l-4 border-fpt-green translate-y-8">
                <div class="text-3xl font-black text-fpt-blue mb-2 italic">02</div>
                <div class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4">Tầm nhìn</div>
                <p class="text-xs text-zinc-500 leading-relaxed">
                    Trở thành đối tác chiến lược hàng đầu trong kỷ nguyên kinh tế số toàn cầu.
                </p>
            </div>
            <div class="p-8 bg-zinc-50 border-l-4 border-fpt-blue">
                <div class="text-3xl font-black text-fpt-blue mb-2 italic">03</div>
                <div class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4">Giá trị</div>
                <p class="text-xs text-zinc-500 leading-relaxed">
                    Chất lượng quốc tế, am hiểu nội địa, sáng tạo không ngừng.
                </p>
            </div>
            <div class="p-8 bg-zinc-50 border-l-4 border-zinc-300 translate-y-8">
                <div class="text-3xl font-black text-fpt-blue mb-2 italic">04</div>
                <div class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4">Kết nối</div>
                <p class="text-xs text-zinc-500 leading-relaxed">
                    Hợp tác để cùng kiến tạo những giá trị mới cho cộng đồng.
                </p>
            </div>
        </div>
        
        <div>
            <h2 class="text-3xl font-black text-fpt-blue mb-8 uppercase tracking-wide leading-tight">
                Tiêu chuẩn công nghệ <br /> <span class="text-fpt-orange italic">Vươn tầm quốc tế</span>
            </h2>
            <div class="space-y-6">
                <div class="flex gap-6">
                    <div class="flex-shrink-0 w-12 h-12 bg-fpt-orange text-white flex items-center justify-center -skew-x-[13deg]">
                        <LucideIcon Name="globe" class="w-6 h-6 skew-x-[13deg]" />
                    </div>
                    <div>
                        <h4 class="text-sm font-bold uppercase text-fpt-blue mb-2">Mạng lưới toàn cầu</h4>
                        <p class="text-xs text-zinc-500">Mạng lưới chi nhánh trải rộng trên 28 quốc gia và vùng lãnh thổ.</p>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="flex-shrink-0 w-12 h-12 bg-fpt-green text-white flex items-center justify-center -skew-x-[13deg]">
                        <LucideIcon Name="check-circle" class="w-6 h-6 skew-x-[13deg]" />
                    </div>
                    <div>
                        <h4 class="text-sm font-bold uppercase text-fpt-blue mb-2">Chất lượng tin cậy</h4>
                        <p class="text-xs text-zinc-500">Quy trình sản xuất phần mềm theo tiêu chuẩn CMMI Level 5.</p>
                    </div>
                </div>
            </div>
            <button class="mt-12 btn-fpt-outline">Tìm hiểu thêm về FPT</button>
        </div>
    </div>
</section>

<!-- FPT Pillars Section -->
<section class="py-24 bg-zinc-50 border-y border-border">
    <div class="max-w-7xl mx-auto px-6">
        <h2 class="fpt-section-title">Giá trị cốt lõi</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="fpt-card">
                <div class="w-12 h-12 flex items-center justify-center text-fpt-orange mb-6 bg-fpt-orange/5">
                    <LucideIcon Name="zap" class="w-6 h-6" />
                </div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-tight text-fpt-blue">Năng động & Sáng tạo</h3>
                <p class="text-sm text-zinc-600 leading-relaxed">
                    Màu cam đại diện cho sự ấm áp, sinh lực và nhiệt huyết sáng tạo. Nexus mang lại tốc độ xử lý vượt trội cho mọi nghiệp vụ.
                </p>
            </div>

            <div class="fpt-card fpt-card-green">
                <div class="w-12 h-12 flex items-center justify-center text-fpt-green mb-6 bg-fpt-green/5">
                    <LucideIcon Name="trending-up" class="w-6 h-6" />
                </div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-tight text-fpt-blue">Phát triển bền vững</h3>
                <p class="text-sm text-zinc-600 leading-relaxed">
                    Màu xanh lá đại diện cho sức sống mãnh liệt và sự hòa hợp. Nexus đồng hành cùng lộ trình tăng trưởng dài hạn của doanh nghiệp.
                </p>
            </div>

            <div class="fpt-card fpt-card-blue">
                <div class="w-12 h-12 flex items-center justify-center text-fpt-blue mb-6 bg-fpt-blue/5">
                    <LucideIcon Name="shield" class="w-6 h-6" />
                </div>
                <h3 class="text-lg font-bold mb-4 uppercase tracking-tight text-fpt-blue">Trí tuệ & Thống nhất</h3>
                <p class="text-sm text-zinc-600 leading-relaxed">
                    Màu xanh dương đậm đại diện cho năng lượng vũ trụ và tính bền vững. Hệ thống bảo mật đa lớp chuẩn quốc tế.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Data Management Section (Nexus Table) -->
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
            <div class="max-w-2xl">
                <h2 class="text-3xl font-bold text-fpt-blue mb-4 uppercase tracking-tight">Vận hành theo thời gian thực</h2>
                <p class="text-zinc-600 text-sm">Quản lý hiệu quả danh mục dự án, nhân sự và các chỉ số kinh doanh then chốt thông qua giao diện DataGrid hiện đại.</p>
            </div>
            <div class="flex gap-3">
                <button class="btn-fpt-outline px-4 py-2 flex items-center gap-2">
                    <LucideIcon Name="download" class="w-4 h-4" /> Xuất báo cáo
                </button>
                <button class="btn-fpt px-4 py-2 flex items-center gap-2">
                    <LucideIcon Name="plus" class="w-4 h-4" /> Thêm bản ghi
                </button>
            </div>
        </div>

        <div class="fpt-table-wrap mt-12">
            <div class="fpt-table-header">
                <div class="flex items-center gap-4">
                    <span class="text-xs font-bold uppercase text-zinc-400">Dữ liệu hệ thống</span>
                    <Badge Variant="BadgeVariant.Outline" class="border-fpt-orange text-fpt-orange rounded-none text-[10px] px-2">LIVE DATA</Badge>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-fpt-green animate-pulse"></div>
                    <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Sẵn sàng</span>
                </div>
            </div>
            
            <DataGrid TItem="PipelineRecord" Items="@_pipelineRecords" class="border-none">
                <Columns>
                    <DataGridColumn TItem="PipelineRecord" Field="ProjectName" Header="Tên dự án" Sortable="true" Filterable="true" />
                    <DataGridColumn TItem="PipelineRecord" Header="Trạng thái" Sortable="true">
                        <CellTemplate Context="record">
                            <div class="flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full" style="background-color: @(record.Status == "Hoàn thành" ? "oklch(var(--fpt-green))" : record.Status == "Đang thực hiện" ? "oklch(var(--fpt-orange))" : "oklch(var(--fpt-blue))")"></div>
                                <span class="text-xs font-medium">@record.Status</span>
                            </div>
                        </CellTemplate>
                    </DataGridColumn>
                    <DataGridColumn TItem="PipelineRecord" Field="ProjectValue" Header="Giá trị (USD)" Sortable="true" Filterable="true" />
                    <DataGridColumn TItem="PipelineRecord" Header="Tiến độ" HeaderClass="w-48">
                        <CellTemplate Context="record">
                            <div class="flex flex-col gap-1 w-full max-w-[120px]">
                                <div class="flex justify-between text-[10px] font-bold text-zinc-400">
                                    <span>@record.Progress%</span>
                                </div>
                                <div class="h-1 w-full bg-zinc-100 overflow-hidden">
                                    <div class="h-full bg-fpt-orange" style="width: @record.Progress%"></div>
                                </div>
                            </div>
                        </CellTemplate>
                    </DataGridColumn>
                </Columns>
            </DataGrid>
        </div>
    </div>
</section>

<!-- FPT Trust Section -->
<section class="py-20 bg-fpt-blue text-white overflow-hidden relative">
    <div class="fpt-bg-13 absolute top-0 left-0 w-full h-full opacity-5 bg-white"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-12 text-center">
            <div>
                <div class="text-4xl font-black mb-2 italic">20+</div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-white/60">Năm kinh nghiệm</div>
            </div>
            <div>
                <div class="text-4xl font-black mb-2 italic">500+</div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-white/60">Đối tác toàn cầu</div>
            </div>
            <div>
                <div class="text-4xl font-black mb-2 italic">10K+</div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-white/60">Nhân sự tài năng</div>
            </div>
            <div>
                <div class="text-4xl font-black mb-2 italic">Top 10</div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-white/60">DN Công nghệ VN</div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<PipelineRecord> _pipelineRecords = new()
    {
        new PipelineRecord { ProjectName = "Chuyển đổi số Ngân hàng A", Status = "Hoàn thành", ProjectValue = "$1,200,000", Progress = 100 },
        new PipelineRecord { ProjectName = "Hệ thống ERP Tập đoàn B", Status = "Đang thực hiện", ProjectValue = "$850,000", Progress = 65 },
        new PipelineRecord { ProjectName = "Cloud Migration Logistics C", Status = "Lập kế hoạch", ProjectValue = "$450,000", Progress = 15 },
        new PipelineRecord { ProjectName = "Smart Factory Solution D", Status = "Đang thực hiện", ProjectValue = "$2,100,000", Progress = 40 },
        new PipelineRecord { ProjectName = "Data Analytics Retail E", Status = "Hoàn thành", ProjectValue = "$320,000", Progress = 100 }
    };

    public class PipelineRecord
    {
        public string ProjectName { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string ProjectValue { get; set; } = string.Empty;
        public int Progress { get; set; }
    }
}
