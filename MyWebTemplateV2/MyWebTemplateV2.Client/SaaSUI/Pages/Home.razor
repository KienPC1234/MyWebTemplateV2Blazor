                    Liên hệ đội ngũ
                </Button>
            </div>
        </div>
    </div>
</section>

@code {
    // Switches
    bool _emailNotifs = true;
    bool _alertNotifs = true;
    bool _updateNotifs = false;
    bool _sheetOpen = false;
    bool _pipelineEnabled = true;

    // Slider / Rating
    double _cpuThreshold = 75;
    double _priorityDouble = 4;

    // DataTable data
    record PipelineRecord(string Name, string Status, int Records, string LastRun);

    List<PipelineRecord> _pipelines = new()
    {
        new("Daily Revenue Sync", "✅ Thành công", 12_430, "09/04/2026 06:00"),
        new("Customer 360 View", "✅ Thành công", 5_821, "09/04/2026 05:30"),
        new("Inventory Update", "⏳ Đang chạy", 3_102, "09/04/2026 06:15"),
        new("Marketing Attribution", "⚠️ Cảnh báo", 8_750, "08/04/2026 23:00"),
        new("Product Analytics", "✅ Thành công", 21_900, "09/04/2026 04:00"),
        new("Churn Prediction ML", "❌ Lỗi", 0, "08/04/2026 18:00"),
        new("Email Engagement", "✅ Thành công", 6_310, "09/04/2026 03:00"),
    };

    void ShowWelcomeToast() => ToastService.Show("Chào mừng bạn đến với Nexus! 🎉");
    void ShowProToast() => ToastService.Show("Đang chuyển bạn đến trang thanh toán…");
    void SaveSettings() => ToastService.Show("Đã lưu cài đặt thông báo thành công!");
    void CloseSheet() { _sheetOpen = false; ToastService.Show("Đã lưu cấu hình!"); }
}
