</section>

<!-- ==========================================
     INTERACTIVE COMPONENTS DEMO
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="sparkles" Class="h-3 w-3" />
            Component Demo
        </div>
        <h2 class="section-title">Tương tác phong phú</h2>
        <p class="section-subtitle">Khám phá một số component NeoUI được dùng trong Nexus.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Left col: form components -->
        <Card>
            <CardHeader>
                <CardTitle>Cài đặt thông báo</CardTitle>
                <CardDescription>Tùy chỉnh cách bạn nhận thông báo từ hệ thống.</CardDescription>
            </CardHeader>
            <CardContent class="space-y-5">
<div class="space-y-1.5">
                        <label class="text-sm font-medium">Địa chỉ email nhận báo cáo</label>
                        <Input Id="email-report" Placeholder="you@company.com" />
                    </div>
                <div class="flex items-center justify-between py-2">
                    <div>
                        <div class="font-medium text-sm">Thông báo qua email</div>
                        <div class="text-xs text-muted-foreground">Nhận báo cáo hàng ngày qua mail</div>
                    </div>
                    <Switch @bind-Checked="_emailNotifs" />
                </div>
                <div class="flex items-center justify-between py-2">
                    <div>
                        <div class="font-medium text-sm">Cảnh báo sự cố</div>
                        <div class="text-xs text-muted-foreground">Nhận ngay khi có lỗi hệ thống</div>
                    </div>
                    <Switch @bind-Checked="_alertNotifs" />
                </div>
                <div class="flex items-center justify-between py-2">
                    <div>
                        <div class="font-medium text-sm">Cập nhật tính năng</div>
                        <div class="text-xs text-muted-foreground">Thông báo khi có phiên bản mới</div>
                    </div>
                    <Switch @bind-Checked="_updateNotifs" />
                </div>
            </CardContent>
            <CardFooter>
                <Button class="w-full rounded-full" OnClick="@SaveSettings">Lưu cài đặt</Button>
            </CardFooter>
        </Card>

        <!-- Right col: misc components -->
        <div class="space-y-6">
            <!-- Slider + Rating -->
            <Card>
                <CardHeader>
                    <CardTitle>Ngưỡng cảnh báo</CardTitle>
                    <CardDescription>Đặt mức độ sử dụng tài nguyên để kích hoạt cảnh báo.</CardDescription>
                </CardHeader>
                <CardContent class="space-y-4">
                    <div>
                        <div class="flex justify-between text-sm mb-3">
                            <Label>CPU Warning Level</Label>
                            <span class="font-bold text-primary">@_cpuThreshold%</span>
                        </div>
                        <Slider @bind-Value="_cpuThreshold" Min="10" Max="95" Step="5" />
                    </div>
                    <Separator />
                    <div>
                        <Label class="text-sm mb-2 block">Mức độ ưu tiên cảnh báo</Label>
                        <Rating Value="_priorityDouble" MaxRating="5" ReadOnly="false" />
                    </div>
                </CardContent>
            </Card>

            <!-- Dropdown + Popover + Tooltip -->
            <Card>
                <CardHeader>
                    <CardTitle>Thao tác nhanh</CardTitle>
                    <CardDescription>Các tùy chọn nhanh cho pipeline đang chọn.</CardDescription>
                </CardHeader>
                <CardContent class="flex flex-wrap gap-3">
                    <DropdownMenu>
                        <DropdownMenuTrigger AsChild>
                            <Button Variant="ButtonVariant.Outline" class="rounded-full">
                                <LucideIcon Name="more-horizontal" Class="mr-2 h-4 w-4" />
                                Tùy chọn
                            </Button>
                        </DropdownMenuTrigger>
                        <DropdownMenuContent>
                            <DropdownMenuLabel>Pipeline Actions</DropdownMenuLabel>
                            <DropdownMenuSeparator />
                            <DropdownMenuItem OnClick="@(() => ToastService.Show("Đã chạy pipeline!"))"> 
                                <LucideIcon Name="play" Class="mr-2 h-4 w-4" />
                                Chạy ngay
                            </DropdownMenuItem>
                            <DropdownMenuItem>
                                <LucideIcon Name="pencil" Class="mr-2 h-4 w-4" />
                                Chỉnh sửa
                            </DropdownMenuItem>
                            <DropdownMenuItem>
                                <LucideIcon Name="copy" Class="mr-2 h-4 w-4" />
                                Nhân bản
                            </DropdownMenuItem>
                            <DropdownMenuSeparator />
                            <DropdownMenuItem Class="text-destructive">
                                <LucideIcon Name="trash-2" Class="mr-2 h-4 w-4" />
                                Xóa pipeline
                            </DropdownMenuItem>
                        </DropdownMenuContent>
                    </DropdownMenu>

                    <TooltipProvider>
                        <Tooltip>
                            <TooltipTrigger AsChild>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" class="rounded-full">
                                    <LucideIcon Name="info" Class="h-4 w-4" />
                                </Button>
                            </TooltipTrigger>
                            <TooltipContent>Xem tài liệu hướng dẫn pipeline</TooltipContent>
                        </Tooltip>
                    </TooltipProvider>

                    <Sheet @bind-Open="_sheetOpen" Side="SheetSide.Right" >
                        <SheetTrigger AsChild>
                            <Button Variant="ButtonVariant.Secondary" class="rounded-full">
                                <LucideIcon Name="settings" Class="mr-2 h-4 w-4" />
                                Cấu hình
                            </Button>
                        </SheetTrigger>
                        <SheetContent>
                            <SheetHeader>
                                <SheetTitle>Cấu hình Pipeline</SheetTitle>
                                <SheetDescription>Cập nhật các thông số kỹ thuật cho pipeline của bạn.</SheetDescription>
                            </SheetHeader>
                            <div class="py-6 space-y-5">
<div class="space-y-1.5">
                                        <Label For="pipe-name">Tên Pipeline</Label>
                                        <Input Id="pipe-name" Placeholder="VD: Daily Revenue Sync" />
                                    </div>
                                    <div class="space-y-1.5">
                                        <Label For="pipe-schedule">Lịch chạy</Label>
                                        <Input Id="pipe-schedule" Placeholder="VD: 0 6 * * *" />
                                    </div>
                                <div class="flex items-center justify-between">
                                    <Label>Kích hoạt pipeline</Label>
                                    <Switch @bind-Checked="_pipelineEnabled" />
                                </div>
                            </div>
                            <SheetFooter>
                                <Button class="rounded-full" OnClick="@CloseSheet">Lưu thay đổi</Button>
                            </SheetFooter>
                        </SheetContent>
                    </Sheet>
                </CardContent>
            </Card>
        </div>
    </div>
</section>

<!-- ==========================================
     DATA TABLE DEMO
  ========================================== -->
<section class="container mx-auto px-4 mb-20">
    <div class="section-header">
        <div class="section-label">
            <LucideIcon Name="table" Class="h-3 w-3" />
            Quản lý dữ liệu
        </div>
        <h2 class="section-title">Bảng dữ liệu mạnh mẽ</h2>
        <p class="section-subtitle">DataTable với tìm kiếm, sắp xếp và phân trang tích hợp sẵn.</p>
    </div>

    <div class="max-w-5xl mx-auto">
        <DataGrid TItem="PipelineRecord" Items="@_pipelines" PageSize="5" PagingMode="DataGridPagingMode.Client">
            <DataGridColumn Field="@nameof(PipelineRecord.Name)" Header="Tên Pipeline" Sortable="true" Filterable="true" />
            <DataGridColumn Field="@nameof(PipelineRecord.Status)" Header="Trạng thái" Sortable="true" Filterable="true" />
            <DataGridColumn Field="@nameof(PipelineRecord.Records)" Header="Số bản ghi" Sortable="true" Filterable="true" />
            <DataGridColumn Field="@nameof(PipelineRecord.LastRun)" Header="Lần chạy cuối" Sortable="true" Filterable="true" />
        </DataGrid>
    </div>
</section>

