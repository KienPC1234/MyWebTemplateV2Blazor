@page "/lien-he"
@using MyWebTemplateV2.Client.SaaSUI.Components

<PageTitle>Liên hệ | Ngoại khóa nhịp đập</PageTitle>

<section class="py-32 bg-white min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
            <div data-aos="fade-right">
                <h1 class="text-6xl md:text-8xl font-black text-fpt-blue leading-[0.85] tracking-[-0.05em] uppercase mb-8">Kết nối <br/> <span class="text-fpt-orange italic">Với chúng tôi</span></h1>
                <p class="text-sm text-zinc-500 mb-12 max-w-sm font-medium">
                    Mọi thắc mắc về hoạt động ngoại khóa, ấn phẩm Nhái Bén hoặc kỹ thuật website, vui lòng liên hệ Ban truyền thông.
                </p>
                
                <div class="space-y-12">
                    <div class="flex gap-8 group">
                        <div class="w-16 h-16 bg-fpt-orange text-white flex items-center justify-center -skew-x-[13deg] shadow-xl shadow-fpt-orange/20 group-hover:rotate-6 transition-transform">
                            <LucideIcon Name="Mail" Size="32" class="skew-x-[13deg]" />
                        </div>
                        <div>
                            <div class="text-[10px] font-black uppercase text-zinc-400 tracking-widest mb-1">Email chính thức</div>
                            <div class="text-xl font-black text-fpt-blue group-hover:text-fpt-orange transition-colors">contact@fpt.edu.vn</div>
                        </div>
                    </div>
                    <div class="flex gap-8 group">
                        <div class="w-16 h-16 bg-fpt-green text-white flex items-center justify-center -skew-x-[13deg] shadow-xl shadow-fpt-green/20 group-hover:-rotate-6 transition-transform">
                            <LucideIcon Name="PhoneCall" Size="32" class="skew-x-[13deg]" />
                        </div>
                        <div>
                            <div class="text-[10px] font-black uppercase text-zinc-400 tracking-widest mb-1">Hotline hỗ trợ</div>
                            <div class="text-xl font-black text-fpt-blue group-hover:text-fpt-green transition-colors">1900 1234</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="p-12 bg-zinc-50 border border-zinc-100 rounded-[3rem] shadow-2xl shadow-zinc-200/50" data-aos="fade-left">
                <div class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <FptInput Label="Họ và tên" Placeholder="Nguyễn Văn A..." />
                        <FptInput Label="Lớp / Khối" Placeholder="12A1..." />
                    </div>
                    <FptInput Label="Tiêu đề" Placeholder="Tôi muốn hỏi về..." />
                    <FptInput Label="Nội dung" Type="textarea" Rows="5" Placeholder="Nhập nội dung tin nhắn tại đây..." />
                    <FptButton Variant="main" Class="w-full py-6">
                        <span>Gửi tin nhắn</span>
                        <LucideIcon Name="Send" Size="18" />
                    </FptButton>
                </div>
            </div>
        </div>
    </div>
</section>
